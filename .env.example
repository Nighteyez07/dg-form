# .env.example — copy this file to .env and fill in real values.
# SECURITY: .env is listed in .gitignore and must NEVER be committed.
#           Treat OPENAI_API_KEY as a secret; rotate it immediately if exposed.

# ── OpenAI ────────────────────────────────────────────────────────────────────

# Required. Your OpenAI API key. Obtain one at https://platform.openai.com/
OPENAI_API_KEY=

# Optional. The OpenAI model used for form critique vision requests.
# Defaults to gpt-4o if not set.
OPENAI_MODEL=gpt-4o

# ── CORS ──────────────────────────────────────────────────────────────────────

# The browser origin that the API's CORS policy allows.
# In development this is the Vite dev server (or the nginx-proxied address).
# In production, set this to your public frontend URL (e.g. https://example.com).
# TODO: Restrict this to a specific production domain before going live.
CORS_ORIGIN=http://localhost:5173
